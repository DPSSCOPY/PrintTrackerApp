<Window x:Class="PrintTrackerApp.ExportPeriodSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export to Google Sheets" SizeToContent="Height" MinHeight="250" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" Topmost="True" FontFamily="Noto Sans Khmer, Arial">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin" From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.2" DecelerationRatio="0.9"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="White" CornerRadius="12" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="15" ShadowDepth="5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="#107C41" CornerRadius="12,12,0,0" Padding="15,10">
                <Grid>
                    <TextBlock Text="Export to Google Sheets" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <Button Content="✕" Foreground="White" Background="Transparent" BorderThickness="0" FontSize="16" FontWeight="Bold" 
                            HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock Text="សូមជ្រើសរើសសប្ដាហ៍សម្រាប់ Export ទៅកាន់ Google Sheet:" 
                           TextWrapping="Wrap" FontSize="14" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,12"/>
                
                <!-- Select All Checkbox -->
                <CheckBox x:Name="chkSelectAll" Content="ជ្រើសរើសទាំងអស់ (Select All)" 
                          FontSize="13" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"
                          Checked="ChkSelectAll_Checked" Unchecked="ChkSelectAll_Unchecked"/>
                
                <Separator Margin="0,0,0,10" Background="#E2E8F0"/>

                <!-- Checkboxes Container -->
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="lstPeriods">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" 
                                          FontSize="13" Margin="5,4" Foreground="#475569"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- Footer Action Buttons -->
            <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,12,12" Padding="15,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnExport" Content="នាំចេញ (Export)" Height="36" Width="110" 
                            Background="#107C41" Foreground="White" FontWeight="SemiBold" FontSize="13" 
                            BorderThickness="0" Cursor="Hand" Click="BtnExport_Click" Margin="0,0,10,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="បោះបង់ (Cancel)" Height="36" Width="100" 
                            Background="#E2E8F0" Foreground="#475569" FontWeight="SemiBold" FontSize="13" 
                            BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
