<Window x:Class="PrintTrackerApp.AdvancedAutoPrintSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Auto Print Settings" SizeToContent="Height" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F9FAFB" ShowInTaskbar="False">
    
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox" x:Key="ToggleSwitchStyle">
            <Setter Property="Background" Value="#E5E5EA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="40" Height="22">
                                <Border x:Name="Border" CornerRadius="11" Background="{TemplateBinding Background}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
                                
                                <!-- On mark (Vertical line) -->
                                <Rectangle x:Name="OnLabel" Fill="White" Width="2" Height="10" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="9,0,0,0" Visibility="Hidden"/>
                                
                                <!-- Off mark (Circle outline) -->
                                <Ellipse x:Name="OffLabel" Width="8" Height="8" Stroke="#9CA3AF" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <!-- Knob -->
                                <Border x:Name="Knob" Width="18" Height="18" CornerRadius="9" Background="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.2"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" Content="{TemplateBinding Content}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#52C45A"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="OnLabel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OffLabel" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="⚙️ Advanced Auto Print Settings" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,15" Grid.Row="0"/>

        <!-- Function 1: Batch Printing -->
        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" Grid.Row="1">
            <StackPanel>
                <CheckBox x:Name="chkEnableBatchPrinting" Content="Enable Batch Printing Verification" Style="{StaticResource ToggleSwitchStyle}" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,10" ToolTip="Pause printing after N files to check if all files have been stored correctly."/>
                
                <StackPanel Orientation="Horizontal" Margin="25,0,0,0">
                    <TextBlock Text="Batch Size (Files):" VerticalAlignment="Center" Foreground="#4B5563" Width="130"/>
                    <TextBox x:Name="txtBatchSize" Width="60" TextAlignment="Center" PreviewTextInput="NumberValidationTextBox" Padding="4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Function 2: Delays -->
        <Border Background="White" CornerRadius="8" Padding="15" Grid.Row="2">
            <StackPanel>
                <TextBlock Text="Timing &amp; Delays" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,10"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <CheckBox x:Name="chkEnableUiStepDelay" Content="Enable Custom UI Step Delay" Style="{StaticResource ToggleSwitchStyle}" FontWeight="SemiBold" Foreground="#374151" Checked="ChkEnableUiStepDelay_CheckedChanged" Unchecked="ChkEnableUiStepDelay_CheckedChanged"/>
                    <TextBlock Text="(Default: 300 ms)" Foreground="#6B7280" FontStyle="Italic" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="25,0,0,15">
                    <TextBlock Text="UI Step Delay (ms):" VerticalAlignment="Center" Foreground="#4B5563" Width="130" ToolTip="Delay time between UI automation steps (e.g. clicking Print). Increase if PC is slow."/>
                    <TextBox x:Name="txtUiStepDelay" Width="60" TextAlignment="Center" PreviewTextInput="NumberValidationTextBox" Padding="4"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Delay between prints (s):" VerticalAlignment="Center" Foreground="#4B5563" Width="155"/>
                    <TextBox x:Name="txtDelayBetweenPrints" Width="60" TextAlignment="Center" PreviewTextInput="NumberValidationTextBox" Padding="4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Function 3: Page Settings -->
        <Border Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0" Grid.Row="3">
            <StackPanel>
                <TextBlock Text="Page Settings" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,10"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <CheckBox x:Name="chkSkipBlankPage" Content="Skip blank page" Style="{StaticResource ToggleSwitchStyle}" FontWeight="SemiBold" Foreground="#374151" ToolTip="Automatically skip printing blank pages."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="80" Click="BtnCancel_Click"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="80" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
