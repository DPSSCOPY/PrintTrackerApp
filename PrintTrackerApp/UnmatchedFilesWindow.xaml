<Window x:Class="PrintTrackerApp.UnmatchedFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unmatched Files" Height="450" Width="800" WindowStartupLocation="CenterOwner" Background="#F3F4F6">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Unmatched Print Jobs" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,10"/>
        <TextBlock Grid.Row="0" Margin="0,30,0,15" Text="The following print jobs could not be matched to any teacher in the Excel sheet and were not assigned to anyone." TextWrapping="Wrap" Foreground="#4B5563"/>

        <DataGrid x:Name="dgUnmatched" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="White" RowBackground="White" AlternatingRowBackground="#F9FAFB">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Timestamp}" Width="150"/>
                <DataGridTextColumn Header="File Name" Binding="{Binding DocumentName}" Width="*"/>
                <DataGridTextColumn Header="Pages" Binding="{Binding TotalPages}" Width="80"/>
                <DataGridTextColumn Header="Copies" Binding="{Binding Copies}" Width="80"/>
                <DataGridTextColumn Header="Owner (PC Name)" Binding="{Binding Owner}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="2" Content="Close" Width="100" HorizontalAlignment="Right" Margin="0,15,0,0" Padding="5" Click="BtnClose_Click"/>
    </Grid>
</Window>
