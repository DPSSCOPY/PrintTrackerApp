<Window x:Class="PrintTrackerApp.TeacherScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Teacher Schedule Settings" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#F8FAFC" FontFamily="Noto Sans Khmer, Arial">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header area with Title and Search box -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Text="Teacher Settings &amp; Schedules" FontWeight="Bold" FontSize="18" Foreground="#1E293B" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#475569" FontWeight="SemiBold"/>
                <TextBox x:Name="txtSearch" Width="180" Height="25" VerticalAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
            </StackPanel>
        </Grid>
        
        <!-- Main Tab Control -->
        <TabControl x:Name="mainTabControl" Grid.Row="1" SelectionChanged="MainTabControl_SelectionChanged" Background="Transparent" BorderThickness="0">
            <!-- Tab 1: Schedules -->
            <TabItem Header="Schedules" FontSize="15" FontWeight="SemiBold" Padding="15,6">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TabControl x:Name="tabCategory" Grid.Column="0" SelectionChanged="TabCategory_SelectionChanged" Background="Transparent" BorderThickness="0" VerticalAlignment="Bottom">
                            <TabItem Header="All Teachers" FontSize="13" FontWeight="SemiBold"/>
                            <TabItem Header="FT" FontSize="13" FontWeight="SemiBold"/>
                            <TabItem Header="PT" FontSize="13" FontWeight="SemiBold"/>
                            <TabItem Header="KH" FontSize="13" FontWeight="SemiBold"/>
                        </TabControl>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="#666666" FontWeight="SemiBold"/>
                            <ComboBox x:Name="cmbDateFilter" Width="110" Height="25" Margin="0,0,15,0" SelectionChanged="CmbDateFilter_SelectionChanged"/>
                            
                            <TextBlock Text="Range:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="dpStart" Width="110" Height="25" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                            <TextBlock Text=" - " VerticalAlignment="Center" Margin="3,0"/>
                            <DatePicker x:Name="dpEnd" Width="110" Height="25" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                        </StackPanel>
                    </Grid>
                    
                    <DataGrid x:Name="dgSchedule" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                              CanUserSortColumns="False" HeadersVisibility="Column" Background="White" RowHeight="30" FontSize="14"
                              VirtualizingPanel.IsVirtualizing="True" SelectionUnit="CellOrRowHeader"
                              PreviewKeyDown="DgSchedule_PreviewKeyDown" 
                              PreviewMouseMove="DgSchedule_PreviewMouseMove"
                              PreviewMouseLeftButtonDown="DgSchedule_PreviewMouseLeftButtonDown"
                              PreviewMouseLeftButtonUp="DgSchedule_PreviewMouseLeftButtonUp">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E5E7EB"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5,5"/>
                            </Style>
                        </DataGrid.Resources>
                        <!-- Columns generated dynamically in code-behind -->
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Tab 2: Visibility -->
            <TabItem Header="Visibility" FontSize="15" FontWeight="SemiBold" Padding="15,6">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TabControl x:Name="tabCategoryVisibility" Grid.Row="0" SelectionChanged="TabCategoryVisibility_SelectionChanged" Background="Transparent" BorderThickness="0" Margin="0,0,0,8">
                        <TabItem Header="All Teachers" FontSize="13" FontWeight="SemiBold"/>
                        <TabItem Header="FT" FontSize="13" FontWeight="SemiBold"/>
                        <TabItem Header="PT" FontSize="13" FontWeight="SemiBold"/>
                        <TabItem Header="KH" FontSize="13" FontWeight="SemiBold"/>
                    </TabControl>
                    
                    <DataGrid x:Name="dgVisibility" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserSortColumns="True" HeadersVisibility="Column" Background="White" RowHeight="30" FontSize="14">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E5E7EB"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="5,5"/>
                            </Style>
                        </DataGrid.Resources>
                        <!-- Columns generated dynamically in code-behind (Show, Teacher Name) -->
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock x:Name="txtStatus" Text="" Foreground="Green" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Button Content="Save Settings" Background="#107C41" Foreground="White" FontWeight="Bold" Width="140" Height="35" Cursor="Hand" BorderThickness="0" Click="BtnSave_Click" Margin="0,0,10,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Close" Background="#94A3B8" Foreground="White" FontWeight="Bold" Width="100" Height="35" Cursor="Hand" BorderThickness="0" Click="BtnClose_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
