<Window x:Class="PrintTrackerApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="850" SizeToContent="Height" Background="#F0F4F8" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN -->
            <StackPanel Grid.Column="0">
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Printer IP Address:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPrinterIp" Padding="6" BorderBrush="#D1D5DB"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Printer Name (Queue Name):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPrinterName" Padding="6" BorderBrush="#D1D5DB"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="CSV Export Folder:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtCsvPath" Grid.Column="0" IsReadOnly="True" Background="#F9FAFB" Foreground="#4B5563" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0"/>
                        <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowse_Click"/>
                    </Grid>
                </StackPanel>


                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Web Monitor Refresh Interval (Seconds):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbRefreshInterval" Padding="6" BorderBrush="#D1D5DB">
                        <ComboBoxItem Content="1 second (Ultra Fast)" Tag="1"/>
                        <ComboBoxItem Content="2 seconds (Very Fast)" Tag="2"/>
                        <ComboBoxItem Content="3 seconds (Fast)" Tag="3"/>
                        <ComboBoxItem Content="5 seconds (Recommended)" Tag="5"/>
                        <ComboBoxItem Content="10 seconds (Slower)" Tag="10"/>
                        <ComboBoxItem Content="15 seconds (Stable)" Tag="15"/>
                        <ComboBoxItem Content="30 seconds (Eco)" Tag="30"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Print Source Folder (For Verification):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtSourcePath" Grid.Column="0" IsReadOnly="True" Background="#F9FAFB" Foreground="#4B5563" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0"/>
                        <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowseSource_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Foxit Window View (Auto Print):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbFoxitWindowStyle" Padding="6" BorderBrush="#D1D5DB" Margin="0,0,0,10">
                        <ComboBoxItem Content="Normal (Default)" Tag="Normal"/>
                        <ComboBoxItem Content="Minimized (Taskbar Only)" Tag="Minimized"/>
                        <ComboBoxItem Content="Small (Top Left Corner)" Tag="Small"/>
                        <ComboBoxItem Content="Right Half (Side-by-Side)" Tag="RightHalf"/>
                    </ComboBox>
                    
                    <Button Content="Foxit UI Automation Settings..." Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Left" Click="BtnFoxitUISettings_Click"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Delay Between Prints (Seconds):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbDelay" Padding="6" BorderBrush="#D1D5DB">
                        <ComboBoxItem Content="1 Second (Fast)" Tag="1"/>
                        <ComboBoxItem Content="2 Seconds (Default)" Tag="2"/>
                        <ComboBoxItem Content="3 Seconds (Safe)" Tag="3"/>
                        <ComboBoxItem Content="5 Seconds (Slow)" Tag="5"/>
                        <ComboBoxItem Content="10 Seconds (Very Slow)" Tag="10"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

            <!-- RIGHT COLUMN -->
            <StackPanel Grid.Column="2">
                <GroupBox Header="Priority Printing Settings" Margin="0,0,0,15" BorderBrush="#D1D5DB" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Enter comma-separated prefixes (e.g., 1A, 2B, FA-). Priority 1 prints first." Margin="0,0,0,10" Foreground="#6B7280" FontStyle="Italic"/>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkPriority1" Content="Priority 1:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtPriority1" Grid.Column="1" Padding="4" BorderBrush="#D1D5DB" ToolTip="e.g., 1A, 2B, 3A"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkPriority2" Content="Priority 2:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtPriority2" Grid.Column="1" Padding="4" BorderBrush="#D1D5DB" ToolTip="e.g., 4A, 4B"/>
                        </Grid>
                        
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="chkPriority3" Content="Priority 3:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtPriority3" Grid.Column="1" Padding="4" BorderBrush="#D1D5DB" ToolTip="e.g., Pre2All, SMC3"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Google Sheets Integration" Margin="0,0,0,15" BorderBrush="#D1D5DB" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Store credentials securely in your AppData folder (safe from GitHub)." Margin="0,0,0,10" Foreground="#6B7280" FontStyle="Italic"/>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Spreadsheet ID:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtGoogleSpreadsheetId" Padding="6" BorderBrush="#D1D5DB" ToolTip="e.g. 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0" VerticalAlignment="Center">
                            <Button Content="Upload Credentials JSON" Padding="10,5" Background="#0D6EFD" Foreground="White" BorderThickness="0" Click="BtnUploadCredentials_Click"/>
                            <TextBlock x:Name="txtCredentialsStatus" Text="❌ Not Loaded" Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold" Foreground="#DC3545"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>


                <GroupBox Header="Telegram Notification Settings" Margin="0,0,0,15" BorderBrush="#D1D5DB" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Get token from @BotFather. Get Chat ID from @userinfobot." Margin="0,0,0,10" Foreground="#6B7280" FontStyle="Italic"/>
                        
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Bot API URL:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTelegramBotUrl" Padding="6" BorderBrush="#D1D5DB" ToolTip="e.g. https://api.telegram.org/bot"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Bot Token:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtTelegramToken" Padding="6" BorderBrush="#D1D5DB" ToolTip="e.g. 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"/>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Chat ID:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtTelegramChatId" Padding="6" BorderBrush="#D1D5DB" ToolTip="e.g. 123456789, 987654321"/>
                                <Button x:Name="btnTestTelegram" Grid.Column="1" Content="Test Bot" Margin="10,0,0,0" Padding="10,0" Click="BtnTestTelegram_Click" Background="#E5E7EB" BorderBrush="#D1D5DB"/>
                            </Grid>
                        </StackPanel>
                        
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Daily Report Time (HH:mm):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtDailyReportTime" Padding="6" BorderBrush="#D1D5DB" ToolTip="e.g. 17:00"/>
                        </StackPanel>

                        <TextBlock Text="Send Telegram Message when all files are moved to:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                        <CheckBox x:Name="chkNotifySentToPrinter" Content="Sent to Printer" Margin="0,0,0,5"/>
                        <CheckBox x:Name="chkNotifyStoringCompleted" Content="Storing Completed" Margin="0,0,0,5"/>
                        <CheckBox x:Name="chkNotifyPrintCompleted" Content="Print Completed" Margin="0,0,0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="🛠️ PC Health &amp; Diagnostics (ពិនិត្យសុខភាពកុំព្យូទ័រ)" Margin="0,0,0,15" BorderBrush="#0078D4" BorderThickness="1.5" Padding="12">
                    <StackPanel>
                        <TextBlock Text="ពិនិត្យលក្ខខណ្ឌម៉ាស៊ីនទាំង ៥ ចំណុច (WMI, Spooler, Ricoh Driver, Antivirus access, Foxit PDF) ដើម្បីធានាថាដើរ Smooth ១០០% ដូច PC Debug។" TextWrapping="Wrap" Foreground="#4B5563" Margin="0,0,0,10"/>
                        <Button Content="🔍 Run Diagnostic Tests (បើកឧបករណ៍ពិនិត្យម៉ាស៊ីន)..." Style="{StaticResource ModernButton}" Background="#0D6EFD" Padding="12" Click="BtnRunDiagnostics_Click"/>
                    </StackPanel>
                </GroupBox>

                <Grid Margin="0,0,0,15">
                    <GroupBox Header="System Settings" BorderBrush="#D1D5DB" Padding="10" IsEnabled="False">
                        <GroupBox.Effect>
                            <BlurEffect Radius="5"/>
                        </GroupBox.Effect>
                        <StackPanel>
                            <CheckBox x:Name="chkAutoShutdown" Content="Enable Auto Shut down PC" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,10" Checked="chkAutoShutdown_CheckedChanged" Unchecked="chkAutoShutdown_CheckedChanged"/>
                            <StackPanel x:Name="pnlAutoShutdownOptions" Margin="20,0,0,0" IsEnabled="False">
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="rbShutdownAfterPrint" Content="Delay after Print Complete:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="txtShutdownDelay" Width="50" Padding="4" BorderBrush="#D1D5DB" ToolTip="Minutes before shutdown"/>
                                        <TextBlock Text=" Min" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <RadioButton x:Name="rbShutdownAtTime" Content="At Specific Time (24H):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtShutdownTime" Grid.Column="1" Width="80" Padding="4" BorderBrush="#D1D5DB" ToolTip="Format: HH:mm (e.g. 18:00)"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    
                    <Border Background="#33FFFFFF" CornerRadius="4">
                        <TextBlock Text="Coming Soon" FontSize="20" FontWeight="Bold" Foreground="#4B5563" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="White" BlurRadius="5" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- FOOTER BUTTONS -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,10">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="80" Click="BtnCancel_Click"/>
            <Button Content="Save" Style="{StaticResource ModernButton}" Width="80" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
