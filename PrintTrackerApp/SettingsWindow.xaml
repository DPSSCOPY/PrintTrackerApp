<Window x:Class="PrintTrackerApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="480" Width="450" Background="#F0F4F8" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Printer IP Address:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPrinterIp" Padding="6" BorderBrush="#D1D5DB"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Printer Name (Queue Name):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPrinterName" Padding="6" BorderBrush="#D1D5DB"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="CSV Export Folder:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtCsvPath" Grid.Column="0" IsReadOnly="True" Background="#F9FAFB" Foreground="#4B5563" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0"/>
                <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowse_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Web Monitor Refresh Interval (Seconds):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbRefreshInterval" Padding="6" BorderBrush="#D1D5DB">
                <ComboBoxItem Content="3 seconds (Fastest)" Tag="3"/>
                <ComboBoxItem Content="5 seconds (Recommended)" Tag="5"/>
                <ComboBoxItem Content="10 seconds (Slower)" Tag="10"/>
                <ComboBoxItem Content="15 seconds (Stable)" Tag="15"/>
                <ComboBoxItem Content="30 seconds (Eco)" Tag="30"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="Print Source Folder (For Verification):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtSourcePath" Grid.Column="0" IsReadOnly="True" Background="#F9FAFB" Foreground="#4B5563" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0"/>
                <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowseSource_Click"/>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,15">
            <TextBlock Text="Foxit Window View (Auto Print):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbFoxitWindowStyle" Padding="6" BorderBrush="#D1D5DB">
                <ComboBoxItem Content="Normal (Default)" Tag="Normal"/>
                <ComboBoxItem Content="Minimized (Taskbar Only)" Tag="Minimized"/>
                <ComboBoxItem Content="Small (Top Left Corner)" Tag="Small"/>
                <ComboBoxItem Content="Right Half (Side-by-Side)" Tag="RightHalf"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="0,0,0,15">
            <TextBlock Text="Delay Between Prints (Seconds):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbDelay" Padding="6" BorderBrush="#D1D5DB">
                <ComboBoxItem Content="1 Second (Fast)" Tag="1"/>
                <ComboBoxItem Content="2 Seconds (Default)" Tag="2"/>
                <ComboBoxItem Content="3 Seconds (Safe)" Tag="3"/>
                <ComboBoxItem Content="5 Seconds (Slow)" Tag="5"/>
                <ComboBoxItem Content="10 Seconds (Very Slow)" Tag="10"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Width="80" Click="BtnCancel_Click"/>
            <Button Content="Save" Style="{StaticResource ModernButton}" Width="80" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
