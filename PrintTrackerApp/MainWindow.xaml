<Window x:Class="PrintTrackerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PrintTrackerApp"
        Title="Ricoh Print Tracker &amp; Auto Print - Ver1.0.23" Height="700" Width="850" MinWidth="380" MinHeight="500" Background="#F0F4F8" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged" PreviewKeyDown="Window_PreviewKeyDown" Closing="Window_Closing"
        Icon="icon.png" ShowInTaskbar="True">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/><!--  -->
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A0AABF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E81123"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D13438"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#A80000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="UpdateButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0.0" />
                        <GradientStop Color="#3B82F6" Offset="1.0" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                            <Border.Effect>
                                <DropShadowEffect Color="#3B82F6" Opacity="0.3" BlurRadius="8" ShadowDepth="2" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#818CF8" Offset="0.0" />
                                            <GradientStop Color="#60A5FA" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4F46E5" Offset="0.0" />
                                            <GradientStop Color="#2563EB" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="0,0,5,10"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#005A9E"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="uiScale" ScaleX="1" ScaleY="1"/>
        </Grid.LayoutTransform>
        <TabControl x:Name="mainTabControl" Margin="10" Background="Transparent" BorderThickness="0" SelectionChanged="MainTabControl_SelectionChanged">
        
        <!-- TAB 1: Tracking Print -->
        <TabItem Header="📊 Tracking Print">
            <Grid Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                    <Border.Effect>
                        <DropShadowEffect Color="Gray" Opacity="0.2" BlurRadius="5" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel Orientation="Vertical">
                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="Printer Status:" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" Foreground="#374151"/>
                            <TextBlock x:Name="txtPrinterStatus" Text="Checking..." FontSize="15" FontWeight="Bold" Margin="10,0,15,0" VerticalAlignment="Center"/>
                            
                            <TextBlock Text="Total Pages:" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,0" VerticalAlignment="Center" Foreground="#374151"/>
                            <TextBlock x:Name="txtPageCount" Text="..." FontSize="15" FontWeight="Bold" Margin="10,0,15,0" VerticalAlignment="Center" Foreground="#111827"/>
                            
                            <Button Content="Refresh Status" Style="{StaticResource SecondaryButton}" Margin="0,5,20,0" Click="BtnRefresh_Click"/>

                            <TextBlock Text="File Printed:" FontWeight="Bold" FontSize="18" Foreground="#0F172A" VerticalAlignment="Center" Margin="0,5,0,0"/>
                            <Border Background="#22C55E" CornerRadius="16" MinWidth="45" Height="40" Margin="10,5,5,0" Padding="10,0">
                                <TextBlock x:Name="txtSubfolderCount" Text="0" Foreground="Black" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Actual unique files printed"/>
                            </Border>

                            <TextBlock Text="Sent to Printer:" FontWeight="Bold" FontSize="15" Foreground="#0F172A" VerticalAlignment="Center" Margin="15,5,0,0"/>
                            <Border Background="#3B82F6" CornerRadius="16" MinWidth="45" Height="40" Margin="10,5,5,0" Padding="10,0">
                                <TextBlock x:Name="txtSentToPrinterCount" Text="0" Foreground="White" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Files sent to printer but not yet stored"/>
                            </Border>
                            <Button Content="Details" Style="{StaticResource SecondaryButton}" Height="30" Padding="15,0" Margin="0,5,0,0" FontSize="14" FontWeight="Bold" Click="BtnShowSentToPrinter_Click"/>

                            <TextBlock Text="Duplicate Files:" FontWeight="Bold" FontSize="15" Foreground="#0F172A" VerticalAlignment="Center" Margin="15,5,0,0"/>
                            <Border Background="#FACC15" CornerRadius="16" MinWidth="45" Height="40" Margin="10,5,15,0" Padding="10,0">
                                <TextBlock x:Name="txtDuplicateCount" Text="0" Foreground="Black" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Number of duplicate files"/>
                            </Border>
                            <Button Content="Details" Style="{StaticResource SecondaryButton}" Height="30" Padding="15,0" Margin="0,5,0,0" FontSize="14" FontWeight="Bold" Click="BtnShowSubfolderDetails_Click"/>

                            <TextBlock Text="Error Files:" FontWeight="Bold" FontSize="15" Foreground="#0F172A" VerticalAlignment="Center" Margin="15,5,0,0"/>
                            <Border Background="#EF4444" CornerRadius="16" MinWidth="45" Height="40" Margin="10,5,5,0" Padding="10,0">
                                <TextBlock x:Name="txtErrorFilesCount" Text="0" Foreground="White" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Number of failed print jobs"/>
                            </Border>
                            <Button Content="Details" Style="{StaticResource SecondaryButton}" Height="30" Padding="15,0" Margin="0,5,0,0" FontSize="14" FontWeight="Bold" Click="BtnShowErrorFiles_Click"/>

                            <TextBlock Text="Print Complete:" FontWeight="Bold" FontSize="15" Foreground="#0F172A" VerticalAlignment="Center" Margin="15,5,0,0"/>
                            <Border Background="#10B981" CornerRadius="16" MinWidth="45" Height="40" Margin="10,5,5,0" Padding="10,0">
                                <TextBlock x:Name="txtPrintCompleteCount" Text="0" Foreground="White" FontWeight="ExtraBold" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Number of fully printed jobs"/>
                            </Border>
                            <Button Content="Details" Style="{StaticResource SecondaryButton}" Height="30" Padding="15,0" Margin="0,5,0,0" FontSize="14" FontWeight="Bold" Click="BtnShowPrintComplete_Click"/>
                        </WrapPanel>

                        <WrapPanel Orientation="Horizontal">
                            <Button Content="Settings ⚙️" Style="{StaticResource SecondaryButton}" Margin="0,0,15,10" Click="BtnSettings_Click" ToolTip="Configure Printer IP and Folder"/>
                            
                            <Button Width="40" Height="34" Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="0,0,15,10" Click="BtnNotifications_Click" ToolTip="View Notifications">
                                <Grid>
                                    <TextBlock Text="🔔" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse x:Name="elNewNotification" Width="10" Height="10" Fill="Red" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0" Visibility="Collapsed"/>
                                </Grid>
                            </Button>

                            <Button Content="Open Web Monitor" Style="{StaticResource ModernButton}" Margin="0,0,10,10" Click="BtnOpenWebMonitor_Click"/>
                            <Button Content="Test Print Log" Style="{StaticResource SecondaryButton}" Margin="0,0,0,10" Click="BtnTest_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Folder Print Verification Panel -->
                <Border Grid.Row="1" Background="#E0F2FE" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#BAE6FD" BorderThickness="1">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,20,10" MinWidth="150">
                            <TextBlock Text="Folder Print Verification" FontWeight="Bold" FontSize="14" Foreground="#0369A1"/>
                            <TextBlock x:Name="txtFolderPath" Text="Select a folder in Settings" FontSize="11" Foreground="#0284C7" Margin="0,2,0,0" MaxWidth="300" TextWrapping="Wrap"/>
                        </StackPanel>

                        <WrapPanel Orientation="Horizontal" Margin="0,0,20,10">
                            <TextBlock Text="Files Waiting:" FontWeight="SemiBold" FontSize="14" Foreground="#0F172A" VerticalAlignment="Center"/>
                            <Border Background="#EF4444" CornerRadius="12" MinWidth="24" Height="24" Margin="10,0,15,0" Padding="5,0">
                                <TextBlock x:Name="txtPendingCount" Text="0" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </WrapPanel>

                        <Button Content="Open Folder" Style="{StaticResource SecondaryButton}" Margin="0,0,0,10" Click="BtnOpenSourceFolder_Click"/>

                        <Border Background="White" CornerRadius="4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="15,0,0,10" Width="200" Height="34">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" FontSize="14" Foreground="#94A3B8" VerticalAlignment="Center" Margin="8,0,5,0" Grid.Column="0"/>
                                <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" Grid.Column="1" TextChanged="TxtSearch_TextChanged" Margin="0,0,5,0"/>
                                <TextBlock x:Name="txtSearchPlaceholder" Text="Search..." Foreground="#94A3B8" IsHitTestVisible="False" VerticalAlignment="Center" Margin="5,0,0,0" Grid.Column="1" Visibility="Visible"/>
                            </Grid>
                        </Border>
                        
                        <Button Content="Log Data" Style="{StaticResource SecondaryButton}" Margin="15,0,0,10" Click="BtnLoadHistoricalLog_Click"/>
                        <Button x:Name="btnResetLiveLog" Content="Reset Data" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="15,5" Margin="10,0,0,10" Visibility="Collapsed" Click="BtnResetLiveLog_Click"/>
                    </WrapPanel>
                </Border>

                <DataGrid x:Name="dgPrintJobs" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="True" 
                          IsReadOnly="False" Background="White" RowBackground="White" AlternatingRowBackground="#F9FAFB" 
                          BorderBrush="#E5E7EB" BorderThickness="1" HorizontalGridLinesBrush="#E5E7EB" VerticalGridLinesBrush="#E5E7EB"
                          HeadersVisibility="Column" SelectionMode="Extended" SelectionUnit="CellOrRowHeader" RowHeight="32" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          PreviewMouseWheel="DgPrintJobs_PreviewMouseWheel"
                          CellEditEnding="DgPrintJobs_CellEditEnding"
                          PreviewKeyDown="DgPrintJobs_PreviewKeyDown"
                          PreviewMouseMove="DgPrintJobs_PreviewMouseMove"
                          PreviewMouseLeftButtonDown="DgPrintJobs_PreviewMouseLeftButtonDown"
                          PreviewMouseLeftButtonUp="DgPrintJobs_PreviewMouseLeftButtonUp">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <EventSetter Event="MouseDoubleClick" Handler="DataGrid_MouseDoubleClick_AutoFit"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.LayoutTransform>
                        <ScaleTransform x:Name="dgScale" ScaleX="1" ScaleY="1"/>
                    </DataGrid.LayoutTransform>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete" Click="MenuItemDeleteJob_Click"/>
                            <MenuItem Header="Cancel" Click="MenuItemCancelMenu_Click"/>
                            <Separator/>
                            <MenuItem Header="Add Blank Row" Click="MenuItemAddBlankRow_Click"/>
                            <MenuItem Header="Add Column" Click="MenuItemAddColumn_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                        <DataGridTextColumn Header="Document Name" Binding="{Binding DocumentName}" Width="*"/>
                        <DataGridTextColumn Header="Hold Print Name" Binding="{Binding WebFileName}" Width="200"/>
                        <DataGridTextColumn Header="User ID (Hold)" Binding="{Binding RicohUserId}" Width="120"/>
                        <DataGridTextColumn Header="Pages" Binding="{Binding TotalPages}" Width="60"/>
                        <DataGridTextColumn Header="Copies" Binding="{Binding Copies}" Width="60"/>
                        <DataGridTextColumn Header="User" Binding="{Binding Owner}" Width="100"/>
                        <DataGridTextColumn Header="Printer Name" Binding="{Binding PrinterName}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </TabItem>

        <!-- TAB 2: Print Options -->
        <TabItem Header="🖨️ Auto Print">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Auto Print Settings" FontSize="20" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15" Grid.Row="0"/>

                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" Grid.Row="1">
                        <Border.Effect>
                            <DropShadowEffect Color="Gray" Opacity="0.1" BlurRadius="5" ShadowDepth="1"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                <TextBlock Text="Folder to Watch:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtWatchFolder" Grid.Column="0" IsReadOnly="True" Background="#F9FAFB" Foreground="#4B5563" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowseWatchFolder_Click"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                <TextBlock Text="Foxit PDF Path (Leave empty to use Default App):" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtFoxitPath" Grid.Column="0" Background="#FFFFFF" Foreground="#1F2937" BorderBrush="#D1D5DB" Padding="6" Margin="0,0,5,0" ToolTip="e.g. C:\Program Files (x86)\Foxit Software\Foxit PDF Reader\FoxitPDFReader.exe"/>
                                    <Button Content="Browse..." Grid.Column="1" Style="{StaticResource SecondaryButton}" Width="80" Click="BtnBrowseFoxit_Click"/>
                                </Grid>
                            </StackPanel>

                            
                            
                            <StackPanel Grid.Row="2" Margin="0,0,0,5" Orientation="Horizontal">
                                <Button Content="Save Settings" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="BtnSaveSettings_Click" Margin="0,0,10,0"/>
                                <Button Content="Show Error File" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="BtnShowErrorFiles_Click"/>
                                <Button Style="{StaticResource SecondaryButton}" Width="40" Height="34" Margin="10,0,0,0" ToolTip="Advanced Auto Print Settings" Click="BtnAdvancedAutoPrintSettings_Click">
                                    <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" Grid.Row="2">
                        <Border.Effect>
                            <DropShadowEffect Color="Gray" Opacity="0.1" BlurRadius="5" ShadowDepth="1"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Status:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtAutoPrintStatus" Text="Stopped" FontWeight="Bold" Foreground="#EF4444" FontSize="16" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Current File:" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtCurrentFile" Text="None" Foreground="#1F2937" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <WrapPanel Grid.Row="5" HorizontalAlignment="Center">
                        <Button x:Name="btnStartAutoPrint" Content="START AUTO PRINT" Style="{StaticResource ModernButton}" Height="40" MinWidth="150" Margin="5" Click="BtnStartAutoPrint_Click"/>
                        <Button x:Name="btnPauseAutoPrint" Content="PAUSE" Style="{StaticResource SecondaryButton}" Height="40" MinWidth="100" Margin="5" IsEnabled="False" Click="BtnPauseAutoPrint_Click"/>
                        <Button x:Name="btnStopAutoPrint" Content="STOP AUTO PRINT" Style="{StaticResource DangerButton}" Height="40" MinWidth="150" Margin="5" IsEnabled="False" Click="BtnStopAutoPrint_Click"/>
                    </WrapPanel>
                    
                    <!-- Manual Testing Panel -->
                    <Expander Header="🛠️ Manual Testing &amp; Debugging Tools" Grid.Row="6" Margin="0,15,0,0" IsExpanded="False" Foreground="#374151" FontWeight="SemiBold">
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,5,0,0">
                            <StackPanel>
                                <TextBlock Text="Open Foxit with a file and follow these steps manually:" FontStyle="Italic" Margin="0,0,0,10"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="1. Test Ctrl+P" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_CtrlP_Click"/>
                                    <Button Content="2. Test Set Copies" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_SetCopies_Click"/>
                                    <Button Content="3. Test Orientation Edge" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_OrientationEdge_Click"/>
                                    <Button Content="4. Test Click Properties" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_Properties_Click"/>
                                    <Button Content="5. Click Details" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_ClickDetails_Click"/>
                                    <Button Content="6. Input ID &amp; File Name" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_InputID_Click"/>
                                    <Button Content="7. OK (Job Details)" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_OKJobDetails_Click"/>
                                    <Button Content="8. OK (Properties)" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_OKProperties_Click"/>
                                    <Button Content="9. OK (Print)" Style="{StaticResource SecondaryButton}" Margin="0,0,5,5" Click="BtnTest_OKPrint_Click"/>
                                </WrapPanel>
                                
                                <Button Content="🔍 Developer Tool: Inspect UI Automation IDs" Margin="0,10,0,0" Style="{StaticResource SecondaryButton}" Click="BtnInspectUI_Click"/>
                            </StackPanel>
                        </Border>
                    </Expander>
                </Grid>
            </ScrollViewer>
        </TabItem>

        <!-- TAB 3: Dashboard -->
        <TabItem Header="👨‍🏫 Dashboard" x:Name="tabDashboard">
            <local:TeacherDashboardControl x:Name="teacherDashboard" />
        </TabItem>
        </TabControl>

        <!-- Top Right Overlays -->
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,20,0" MaxWidth="300">
            
            <StackPanel x:Name="pnlTopControls" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed">
                <Button x:Name="btnTopPause" Width="45" Height="45" Margin="0,0,5,0" Style="{StaticResource SecondaryButton}" Click="BtnPauseAutoPrint_Click" ToolTip="Pause/Resume Auto Print">
                    <StackPanel>
                        <TextBlock x:Name="txtTopPauseIcon" Text="⏸" FontSize="16" Foreground="#D97706" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtTopPauseText" Text="Pause" FontSize="9" Foreground="#D97706" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="btnTopStop" Width="45" Height="45" Margin="0,0,0,0" Style="{StaticResource SecondaryButton}" Click="BtnStopAutoPrint_Click" ToolTip="Stop Auto Print">
                    <StackPanel>
                        <TextBlock Text="⏹" FontSize="16" Foreground="#DC2626" HorizontalAlignment="Center"/>
                        <TextBlock Text="Stop" FontSize="9" Foreground="#DC2626" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Running Timer Overlay -->
            <Border x:Name="borderRunTimer" Background="#1F2937" CornerRadius="6" Padding="12,5" Visibility="Collapsed" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⏱ " FontSize="18" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock x:Name="txtRunTimer" Text="00:00:00" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Update Button Overlay -->
            <Grid>
                <Button x:Name="btnUpdate" Content="✨ Check Update" Style="{StaticResource UpdateButton}" Click="BtnUpdate_Click"/>
                <!-- Notification Badge -->
                <Border x:Name="borderUpdateBadge" Background="#EF4444" BorderBrush="White" BorderThickness="2" CornerRadius="12" MinWidth="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-8,0" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="#EF4444" Opacity="0.5" BlurRadius="6" ShadowDepth="1" Direction="270" />
                    </Border.Effect>
                    <TextBlock x:Name="txtUpdateBadge" Text="1" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,4,1"/>
                </Border>
            </Grid>
        </WrapPanel>
    </Grid>
</Window>
