<Window x:Class="PrintTrackerApp.SystemDiagnosticWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🛠️ PC Health &amp; Diagnostic Tool (ឧបករណ៍ពិនិត្យសុខភាពកុំព្យូទ័រ)" 
        Width="780" Height="680" MinWidth="600" MinHeight="500"
        Background="#F0F4F8" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="#D1D5DB" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#1F2937" BlurRadius="6" ShadowDepth="1" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER BANNER -->
        <Border Grid.Row="0" Background="#0078D4" CornerRadius="8" Padding="16" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🛠️ PC Health &amp; Diagnostic Tool" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Text="ពិនិត្យលក្ខខណ្ឌម៉ាស៊ីនទាំង ៥ ចំណុច ដើម្បីឱ្យកម្មវិធីដំណើរការបានលឿន និង Smooth ១០០% ដូច PC Debug" FontSize="13" Foreground="#E0F2FE" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="btnRunAll" Grid.Column="1" Content="🚀 Test All (ពិនិត្យទាំងអស់)" Style="{StaticResource ModernButton}" Background="#10B981" Padding="15,10" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Click="BtnRunAll_Click"/>
            </Grid>
        </Border>

        <!-- SUMMARY STATUS -->
        <Border x:Name="borderSummary" Grid.Row="1" Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,15" Visibility="Collapsed">
            <TextBlock x:Name="txtSummary" Text="ℹ️ Click 'Test All' or test each function below to verify PC readiness." Foreground="#92400E" FontWeight="SemiBold" TextWrapping="Wrap"/>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="2">
                <!-- 1. RICOH DRIVER -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="1. 🖨️ Ricoh Printer Driver Type Check" FontSize="15" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,4"/>
                            <TextBlock Text="ពិនិត្យប្រភេទ Driver ម៉ាស៊ីន Print ថាតើជា PCL6 ផ្លូវការ ឬជា WSD/IPP ដែលដើរយឺត។" FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtStatusDriver" Text="⏳ Ready to check..." FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="btnTestDriver" Grid.Column="1" Content="Test Driver" Style="{StaticResource SecondaryButton}" Width="100" VerticalAlignment="Center" Click="BtnTestDriver_Click"/>
                    </Grid>
                </Border>

                <!-- 2. SPOOLER SERVICE -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="2. ⚙️ Spooler Service &amp; Antivirus Permission Check" FontSize="15" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,4"/>
                            <TextBlock Text="ពិនិត្យល្បឿន Spooler និងសិទ្ធិអាន/សរសេរឯកសារ .SPL ក្នុង Folder ដើម្បីកុំឱ្យ Antivirus Lock។" FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtStatusSpooler" Text="⏳ Ready to check..." FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="btnTestSpooler" Grid.Column="1" Content="Test Spooler" Style="{StaticResource SecondaryButton}" Width="100" VerticalAlignment="Center" Click="BtnTestSpooler_Click"/>
                    </Grid>
                </Border>

                <!-- 3. FOXIT PDF READER -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="3. 📄 Foxit PDF Reader Accessibility Check" FontSize="15" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,4"/>
                            <TextBlock Text="ពិនិត្យការដំឡើង និងការតភ្ជាប់កម្មវិធី Foxit PDF សម្រាប់ការបញ្ជា Auto Print។" FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtStatusFoxit" Text="⏳ Ready to check..." FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="btnTestFoxit" Grid.Column="1" Content="Test Foxit" Style="{StaticResource SecondaryButton}" Width="100" VerticalAlignment="Center" Click="BtnTestFoxit_Click"/>
                    </Grid>
                </Border>

                <!-- 4. WMI MONITORING HEALTH -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="4. ⚡ WMI Event Monitoring Health Check" FontSize="15" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,4"/>
                            <TextBlock Text="វាស់ល្បឿនឆ្លើយតបរបស់ប្រព័ន្ធ WMI Windows (Win32_PrintJob) ធានាការចាប់ Print ភ្លាមៗអត់គាំង។" FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtStatusWmi" Text="⏳ Ready to check..." FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="btnTestWmi" Grid.Column="1" Content="Test WMI" Style="{StaticResource SecondaryButton}" Width="100" VerticalAlignment="Center" Click="BtnTestWmi_Click"/>
                    </Grid>
                </Border>

                <!-- 5. CSV STORAGE PERMISSION -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="5. 📁 CSV Export &amp; Storage Permission Check" FontSize="15" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,4"/>
                            <TextBlock Text="ពិនិត្យសិទ្ធិសរសេរទិន្នន័យចូលក្នុង Folder រក្សាទុក CSV ធានាថាអត់មាន Error ដោយសារ Excel Lock។" FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtStatusCsv" Text="⏳ Ready to check..." FontSize="13" FontWeight="SemiBold" Foreground="#4B5563" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button x:Name="btnTestCsv" Grid.Column="1" Content="Test CSV" Style="{StaticResource SecondaryButton}" Width="100" VerticalAlignment="Center" Click="BtnTestCsv_Click"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER BAR -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" Style="{StaticResource SecondaryButton}" Width="90" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
