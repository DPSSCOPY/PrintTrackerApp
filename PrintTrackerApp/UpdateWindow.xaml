<Window x:Class="PrintTrackerApp.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Software Update" Height="450" Width="600" WindowStartupLocation="CenterScreen"
        Background="#F9FAFB" ResizeMode="NoResize" Topmost="True" Icon="icon.png">
    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#E1DFDD"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C8C6C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🚀 A New Update is Available!" FontSize="22" FontWeight="Bold" Foreground="#323130" Margin="0,0,0,5"/>
            <TextBlock x:Name="txtVersionInfo" Text="Version X.X.X is available. (You have Y.Y.Y)" FontSize="14" Foreground="#605E5C"/>
        </StackPanel>

        <!-- Release Notes Label -->
        <TextBlock Grid.Row="1" Text="What's New:" FontSize="16" FontWeight="SemiBold" Foreground="#323130" Margin="0,0,0,10"/>

        <!-- Release Notes Content -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E1DFDD" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="txtReleaseNotes" Text="Loading release notes..." TextWrapping="Wrap" FontSize="14" Foreground="#323130"/>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Remind me in:" VerticalAlignment="Center" FontSize="14" Foreground="#605E5C" Margin="0,0,10,0"/>
            
            <ComboBox x:Name="cmbRemindTime" Grid.Column="1" Width="100" VerticalAlignment="Center" SelectedIndex="3" Padding="5">
                <ComboBoxItem Content="5 mins" Tag="5"/>
                <ComboBoxItem Content="10 mins" Tag="10"/>
                <ComboBoxItem Content="20 mins" Tag="20"/>
                <ComboBoxItem Content="30 mins" Tag="30"/>
                <ComboBoxItem Content="1 hour" Tag="60"/>
            </ComboBox>

            <Button x:Name="btnAskLater" Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Ask Me Later" Margin="10,0,0,0" HorizontalAlignment="Left" Click="BtnAskLater_Click"/>
            
            <Button x:Name="btnDownload" Grid.Column="3" Style="{StaticResource PrimaryButton}" Content="Download Update" HorizontalAlignment="Right" Click="BtnDownload_Click"/>
        </Grid>
    </Grid>
</Window>
